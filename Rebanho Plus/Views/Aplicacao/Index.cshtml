@model Dictionary<string, List<Rebanho_Plus.Models.Aplicacao>>

@{
    ViewData["Title"] = "Histórico de Aplicações";
    var ativas = Model.ContainsKey("Ativo") ? Model["Ativo"] : new List<Rebanho_Plus.Models.Aplicacao>();
    var inativas = Model.ContainsKey("Inativo") ? Model["Inativo"] : new List<Rebanho_Plus.Models.Aplicacao>();
}

<div class="mb-4">
    <a asp-controller="Gado" asp-action="Index" class="btn btn-agro-outline py-2 px-3 mb-3">
        ⬅️ Voltar para o Rebanho
    </a>
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 text-success-custom fw-bold mb-0">💉 Aplicações do Animal #@ViewBag.GadoId</h1>
            <p class="text-muted mb-0">Histórico de vacinas aplicadas neste animal.</p>
        </div>
        <a asp-action="Adicionar" asp-route-gadoId="@ViewBag.GadoId" class="btn btn-agro">
            ➕ Nova Aplicação
        </a>
    </div>
</div>

<!-- Tabs Controladoras com JS -->
<ul class="nav nav-tabs nav-tabs-agro mb-4" id="aplicacaoTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="ativas-tab" data-bs-toggle="tab" data-bs-target="#ativas-content" type="button" role="tab" aria-controls="ativas-content" aria-selected="true">
            🟢 Ativas (@ativas.Count)
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="inativas-tab" data-bs-toggle="tab" data-bs-target="#inativas-content" type="button" role="tab" aria-controls="inativas-content" aria-selected="false">
            🔴 Inativas (@inativas.Count)
        </button>
    </li>
</ul>

<div class="tab-content" id="aplicacaoTabsContent">
    <!-- ABA DAS ATIVAS -->
    <div class="tab-pane fade show active" id="ativas-content" role="tabpanel" aria-labelledby="ativas-tab">
        <div class="card card-agro">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-agro mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Código / ID</th>
                                <th>Vacina</th>
                                <th>Data da Aplicação</th>
                                <th>Status</th>
                                <th class="pe-4 text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!ativas.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        Nenhuma aplicação ativa registrada.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in ativas)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">#@item.Id</td>
                                        <td>@(item.Vacina?.Nome ?? "-")</td>
                                        <td>@item.DataAplicacao.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <span class="badge-status badge-ativo">Ativo</span>
                                        </td>
                                        <td class="pe-4 text-end">
                                            <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-agro-outline py-1 px-2 me-1">
                                                Editar
                                            </a>
                                            <a asp-action="Inativar" asp-route-id="@item.Id" class="btn btn-sm btn-agro-outline py-1 px-2" onclick="return confirm('Deseja inativar esta aplicação?');">
                                                Inativar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- ABA DAS INATIVAS -->
    <div class="tab-pane fade" id="inativas-content" role="tabpanel" aria-labelledby="inativas-tab">
        <div class="card card-agro">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-agro mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Código / ID</th>
                                <th>Vacina</th>
                                <th>Data da Aplicação</th>
                                <th>Status</th>
                                <th class="pe-4 text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!inativas.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        Nenhuma aplicação inativa registrada.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in inativas)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-muted">#@item.Id</td>
                                        <td class="text-muted">@(item.Vacina?.Nome ?? "-")</td>
                                        <td class="text-muted">@item.DataAplicacao.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <span class="badge-status badge-inativo">Inativo</span>
                                        </td>
                                        <td class="pe-4 text-end">
                                            <a asp-action="Ativar" asp-route-id="@item.Id" class="btn btn-sm btn-agro-outline py-1 px-2" onclick="return confirm('Deseja ativar esta aplicação?');">
                                                Ativar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            console.log("Sistema de abas de Aplicações carregado com sucesso.");
        });
    </script>
}