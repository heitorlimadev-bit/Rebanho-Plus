@model Rebanho_Plus.Models.Vacina

@{
    ViewData["Title"] = "Editar Vacina";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-agro-outline py-2 px-3 mb-3">
        ⬅️ Voltar
    </a>

    <h1 class="h2 text-success-custom fw-bold">
        💉 Editar Vacina
    </h1>

    <p class="text-muted">
        Edite uma vacina no sistema.
    </p>
</div>

<div class="card card-agro max-width-card mx-auto shadow-sm">
    <div class="card-header card-header-agro py-3">
        📋 Cadastro de Vacina
    </div>

    <div class="card-body p-4">
        <form asp-action="Editar" method="post">

            <div class="mb-3">
                <label asp-for="Nome" class="form-label fw-medium text-secondary"></label>
                <input asp-for="Nome" class="form-control" required/>
            </div>
            <div class="md-3">
                <label asp-for="Status" class="form-label fw-medium text-secondary">Status</label>
                <select asp-for="Status" class="form-select" required>
                    <option value="1">Ativo</option>
                    <option value="0">Inativo</option>
                </select>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a asp-action="Index" class="btn btn-agro-outline">
                    Cancelar
                </a>

                <button type="submit" class="btn btn-agro px-4">
                    Salvar
                </button>
            </div>

        </form>
    </div>
</div>